<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Engineer Dashboard</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="bg-light">
    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container">
            <a class="navbar-brand" href="#">Factory Management</a>
            <div class="d-flex">
                <span class="navbar-text me-3 text-white">Welcome, <%= user.name %> (Engineer)</span>
                <a href="/logout" class="btn btn-outline-light btn-sm">Logout</a>
            </div>
        </div>
    </nav>

    <div class="container mt-4">
        <h2 class="mb-3">My Assigned Machines</h2>
        
        <div>
            <% if (machines && machines.length > 0) { %>
                <form action="/machines/engineer/mark-done" method="POST">
                    <div class="d-flex justify-content-end mb-3">
                        <button type="submit" class="btn btn-success shadow-sm">Mark Selected as Done</button>
                    </div>
                    <div class="row">
                    <% machines.forEach(m => { %>
                        <div class="col-md-6 mb-4">
                            <div class="card shadow-sm h-100 border-<%= m.status === 'Running' ? 'success' : (m.status === 'Maintenance' ? 'danger' : 'secondary') %>">
                                <div class="card-header bg-<%= m.status === 'Maintenance' ? 'danger' : 'light' %> <%= m.status === 'Maintenance' ? 'text-white' : '' %> d-flex justify-content-between align-items-center">
                                    <h5 class="mb-0"><%= m.machine_name %></h5>
                                    <input class="form-check-input mt-0 fs-4" type="checkbox" name="machine_ids" value="<%= m.machine_id %>" aria-label="Select Machine" style="cursor: pointer;">
                                </div>
                                <div class="card-body">
                                    <p class="card-text mb-1"><strong>Location:</strong> <%= m.location %></p>
                                    <p class="card-text mb-1"><strong>Server:</strong> <%= m.server_name %></p>
                                    <p class="card-text mb-3"><strong>Status:</strong> 
                                        <span class="badge bg-<%= m.status === 'Running' ? 'success' : (m.status === 'Maintenance' ? 'danger' : 'secondary') %>">
                                            <%= m.status %>
                                        </span>
                                    </p>
                                    <p class="card-text mb-3"><strong>Work:</strong> 
                                        <span class="badge bg-<%= m.work_status === 'Completed' ? 'success' : (m.work_status === 'In Progress' ? 'warning' : 'info') %> text-dark">
                                            <%= m.work_status %>
                                        </span>
                                    </p>
                                    
                                    <% if (m.status === 'Maintenance') { %>
                                        <div class="alert alert-warning py-2 mb-3">
                                            <i class="bi bi-exclamation-triangle"></i> This machine is marked for maintenance.
                                        </div>
                                        <% if (m.work_status === 'Assigned' || m.work_status === 'Pending') { %>
                                            <button type="submit" formmethod="POST" formaction="/machines/engineer/start-work/<%= m.machine_id %>" class="btn btn-warning w-100 mb-2">
                                                Start Work
                                            </button>
                                        <% } else if (m.work_status === 'In Progress') { %>
                                            <button type="submit" name="machine_ids" value="<%= m.machine_id %>" class="btn btn-success w-100">
                                                Mark Completed
                                            </button>
                                        <% } %>
                                    <% } else { %>
                                        <div class="alert alert-success py-2 mb-0 text-center">
                                            Machine is operating normally.
                                        </div>
                                    <% } %>
                                </div>
                            </div>
                        </div>
                    <% }) %>
                    </div>
                </form>
            <% } else { %>
                <div class="col-12">
                    <div class="alert alert-info">You currently have no machines assigned to you.</div>
                </div>
            <% } %>
        </div>
    </div>
</body>
</html>
