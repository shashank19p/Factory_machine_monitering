<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Admin Dashboard</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="bg-light">
    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container">
            <a class="navbar-brand" href="#">Factory Management</a>
            <div class="d-flex">
                <span class="navbar-text me-3 text-white">Welcome, <%= user.name %> (Admin)</span>
                <a href="/logout" class="btn btn-outline-light btn-sm">Logout</a>
            </div>
        </div>
    </nav>

    <div class="container mt-4">
        <% if (error) { %>
            <div class="alert alert-danger"><%= error %></div>
        <% } %>

        <!-- Machines Section -->
        <h2 class="mb-3">Machines Overview</h2>
        <div class="card shadow-sm mb-5">
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-hover table-bordered mb-0">
                        <thead class="table-dark">
                            <tr>
                                <th>ID</th>
                                <th>Name</th>
                                <th>Location</th>
                                <th>Server</th>
                                <th>Status</th>
                                <th>Work</th>
                                <th>Assigned Worker</th>
                                <th>Assigned Engineer</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (machines && machines.length > 0) { %>
                                <% machines.forEach(m => { %>
                                    <tr>
                                        <td><%= m.machine_id %></td>
                                        <td><%= m.machine_name %></td>
                                        <td><%= m.location %></td>
                                        <td><%= m.server_name %></td>
                                        <td>
                                            <span class="badge 
                                                <%= m.status === 'Running' ? 'bg-success' : (m.status === 'Stopped' ? 'bg-secondary' : 'bg-danger') %>">
                                                <%= m.status %>
                                            </span>
                                        </td>
                                        <td>
                                            <span class="badge bg-<%= m.work_status === 'Completed' ? 'success' : (m.work_status === 'In Progress' ? 'warning' : 'info') %> text-dark">
                                                <%= m.work_status %>
                                            </span>
                                        </td>
                                        <td><%= m.worker_name || 'None' %></td>
                                        <td><%= m.engineer_name || 'None' %></td>
                                    </tr>
                                <% }) %>
                            <% } else { %>
                                <tr><td colspan="7" class="text-center">No machines found.</td></tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Users Section -->
        <h2 class="mb-3">System Users</h2>
        <div class="card shadow-sm">
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-hover table-bordered mb-0">
                        <thead class="table-dark">
                            <tr>
                                <th>ID</th>
                                <th>Name</th>
                                <th>Email</th>
                                <th>Role</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (users && users.length > 0) { %>
                                <% users.forEach(u => { %>
                                    <tr>
                                        <td><%= u.user_id %></td>
                                        <td><%= u.name %></td>
                                        <td><%= u.email %></td>
                                        <td><span class="badge bg-primary text-capitalize"><%= u.role %></span></td>
                                    </tr>
                                <% }) %>
                            <% } else { %>
                                <tr><td colspan="4" class="text-center">No users found.</td></tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</body>
</html>
