<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Worker Dashboard</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="bg-light">
    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container">
            <a class="navbar-brand" href="#">Factory Management</a>
            <div class="d-flex">
                <span class="navbar-text me-3 text-white">Welcome, <%= user.name %> (Worker)</span>
                <a href="/logout" class="btn btn-outline-light btn-sm">Logout</a>
            </div>
        </div>
    </nav>

    <div class="container mt-4">
        <% if (locals.assignedMachines && assignedMachines.length > 0) { %>
            <div class="card bg-light border-warning mb-5 shadow-sm">
                <div class="card-body">
                    <h3 class="card-title text-warning mb-3"><i class="bi bi-card-checklist"></i> My Assigned Follow-ups</h3>
                    <form action="/machines/worker/mark-done" method="POST">
                        <div class="d-flex justify-content-end mb-3">
                            <button type="submit" class="btn btn-warning shadow-sm">Mark Selected as Done</button>
                        </div>
                        <div class="row">
                            <% assignedMachines.forEach(m => { %>
                                <div class="col-md-4 mb-3">
                                    <div class="card h-100 border-warning">
                                        <div class="card-header bg-warning text-dark d-flex justify-content-between align-items-center">
                                            <h5 class="mb-0 fs-6"><%= m.machine_name %></h5>
                                            <input class="form-check-input mt-0 fs-5" type="checkbox" name="machine_ids" value="<%= m.machine_id %>" aria-label="Select Machine" style="cursor: pointer;">
                                        </div>
                                        <div class="card-body py-2">
                                            <p class="mb-1 small"><strong>Status:</strong> <span class="badge bg-<%= m.status === 'Running' ? 'success' : (m.status === 'Stopped' ? 'secondary' : 'danger') %>"><%= m.status %></span></p>
                                            <p class="mb-1 small"><strong>Work:</strong> <span class="badge bg-<%= m.work_status === 'Completed' ? 'success' : (m.work_status === 'In Progress' ? 'warning' : 'info') %> text-dark"><%= m.work_status %></span></p>
                                            <p class="mb-0 small"><strong>Engineer:</strong> <%= m.assigned_engineer_id ? 'Assigned' : 'Pending' %></p>
                                        </div>
                                    </div>
                                </div>
                            <% }) %>
                        </div>
                    </form>
                </div>
            </div>
        <% } %>

        <h2 class="mb-3">All Factory Machines</h2>
        
        <div class="row">
            <% if (machines && machines.length > 0) { %>
                <% machines.forEach(m => { %>
                    <div class="col-md-4 mb-4">
                        <div class="card shadow-sm h-100 border-<%= m.status === 'Running' ? 'success' : (m.status === 'Stopped' ? 'secondary' : 'danger') %>">
                            <div class="card-body">
                                <h5 class="card-title text-primary"><%= m.machine_name %></h5>
                                <p class="card-text mb-1"><strong>Location:</strong> <%= m.location %></p>
                                <p class="card-text mb-1"><strong>Server:</strong> <%= m.server_name %></p>
                                <p class="card-text mb-1"><strong>Status:</strong> 
                                    <span class="badge bg-<%= m.status === 'Running' ? 'success' : (m.status === 'Stopped' ? 'secondary' : 'danger') %>">
                                        <%= m.status %>
                                    </span>
                                </p>
                                <p class="card-text mb-3"><strong>Work:</strong> 
                                    <span class="badge bg-<%= m.work_status === 'Completed' ? 'success' : (m.work_status === 'In Progress' ? 'warning' : 'info') %> text-dark">
                                        <%= m.work_status %>
                                    </span>
                                </p>

                                <div class="btn-group w-100" role="group">
                                    <% if (m.status !== 'Maintenance') { %>
                                        <form action="/machines/mark-damaged/<%= m.machine_id %>" method="POST" class="w-100">
                                            <button type="submit" class="btn btn-warning w-100 rounded-0 rounded-start">Report Damage</button>
                                        </form>
                                    <% } %>
                                    
                                    <button type="button" class="btn btn-primary w-100 rounded-0 rounded-end" data-bs-toggle="modal" data-bs-target="#assignModal<%= m.machine_id %>">
                                        Assign Engineer
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Assign Engineer Modal -->
                    <div class="modal fade" id="assignModal<%= m.machine_id %>" tabindex="-1">
                        <div class="modal-dialog">
                            <form action="/machines/assign-engineer/<%= m.machine_id %>" method="POST">
                                <div class="modal-content">
                                    <div class="modal-header bg-primary text-white">
                                        <h5 class="modal-title">Assign Engineer to <%= m.machine_name %></h5>
                                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                                    </div>
                                    <div class="modal-body">
                                        <div class="mb-3">
                                            <label class="form-label">Select Engineer</label>
                                            <select name="engineer_id" class="form-select" required>
                                                <option value="" disabled selected>Choose an engineer...</option>
                                                <% engineers.forEach(e => { %>
                                                    <option value="<%= e.user_id %>" <%= m.assigned_engineer_id === e.user_id ? 'selected' : '' %>>
                                                        <%= e.name %>
                                                    </option>
                                                <% }) %>
                                            </select>
                                        </div>
                                    </div>
                                    <div class="modal-footer">
                                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                                        <button type="submit" class="btn btn-primary">Assign</button>
                                    </div>
                                </div>
                            </form>
                        </div>
                    </div>
                <% }) %>
            <% } else { %>
                <div class="col-12"><div class="alert alert-info">No machines available.</div></div>
            <% } %>
        </div>
    </div>
    
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
